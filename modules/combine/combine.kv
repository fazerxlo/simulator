<Combine>:
  BoxLayout:
    orientation: 'vertical'

    BoxLayout:
      orientation: 'horizontal'
      ToggleButton:
        id: on
        text: 'on'
        on_state: root.options[self.text] = 1 if self.state == 'down' else 0
        size_hint: 0.1, 1
        state: 'down'
      GridLayout:
        cols: 5
        ToggleButton:
          id: airbag_pass
          text: 'airbag_pass'
          on_state: root.options[self.text] = 1 if self.state == 'down' else 0
