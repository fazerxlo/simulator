<KML>:
  BoxLayout:
    orientation: 'vertical'

    BoxLayout:
      orientation: 'horizontal'
      ToggleButton:
        id: opt
        text: 'opt'
        on_state: root.on_opt(self.state)

    BoxLayout:
      orientation: 'horizontal'
      ToggleButton:
        id: b7
        text: 'b7'
        on_state: root.on_toggle(7, self.state)
      ToggleButton:
        id: b6
        text: 'b6'
        on_state: root.on_toggle(6, self.state)
      ToggleButton:
        id: b5
        text: 'b5'
        on_state: root.on_toggle(5, self.state)
      ToggleButton:
        id: b4
        text: 'b4'
        on_state: root.on_toggle(4, self.state)
      ToggleButton:
        id: b3
        text: 'b3'
        on_state: root.on_toggle(3, self.state)
      ToggleButton:
        id: b2
        text: 'b2'
        on_state: root.on_toggle(2, self.state)
      ToggleButton:
        id: b1
        text: 'b1'
        on_state: root.on_toggle(1, self.state)
      ToggleButton:
        id: b0
        text: 'b0'
        on_state: root.on_toggle(0, self.state)

